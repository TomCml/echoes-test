# ──────────────────────────────────────────────
# Game Balance (prefix: GAME_)
# ──────────────────────────────────────────────
# Toutes ces valeurs ont des défauts sensés dans game_balance.py.
# Ne décommenter que pour override lors du tuning.

# GAME_BASE_XP=100
# GAME_BASE_XP_LEVEL_100=5000
# GAME_XP_PENALTY_DIVISOR=100.0

# Gold par catégorie de monstre
# GAME_GOLD_CAT_1=50
# GAME_GOLD_CAT_2=150
# GAME_GOLD_CAT_3=350
# GAME_GOLD_CAT_4=1000
# GAME_GOLD_SCALING_PER_LEVEL=0.07

# Poids de rareté des coffres (%)
# GAME_CHEST_RARITY_W1=50.0
# GAME_CHEST_RARITY_W2=28.0
# GAME_CHEST_RARITY_W3=15.4
# GAME_CHEST_RARITY_W4=6.0
# GAME_CHEST_RARITY_W5=0.6

# Multiplicateurs de stats par rareté d'instance
# GAME_RARITY_MULT_1=1.0
# GAME_RARITY_MULT_2=1.15
# GAME_RARITY_MULT_3=1.35
# GAME_RARITY_MULT_4=1.60
# GAME_RARITY_MULT_5=2.00

# Difficulté donjons (multiplicateur drop rate)
# GAME_DUNGEON_DIFF_1=1.0
# GAME_DUNGEON_DIFF_2=1.5
# GAME_DUNGEON_DIFF_3=2.0
# GAME_DUNGEON_DIFF_4=3.0
# GAME_DUNGEON_DIFF_5=5.0

# Combat
# GAME_ECHO_GAUGE_MAX=100
# GAME_ECHO_BASE_GAIN=10
# GAME_CRIT_DAMAGE_MULTIPLIER=1.5
# GAME_CHESTS_PER_VICTORY=1
# GAME_BOSS_BONUS_CHESTS=1

# Postgres
POSTGRES_USER=echoes
POSTGRES_PASSWORD=echoes_dev_password
POSTGRES_DB=echoes_db

# App
DATA_DIR=/app/data
